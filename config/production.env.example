# BusinessClaw production environment — Railway / VPS
# Add these as environment variables in Railway's dashboard (Variables tab).
# Never commit this file with real secrets.

ENVIRONMENT=production

# Set this to your Railway-generated URL or custom domain after deployment.
# Example: https://dashboard.kontext.observer
PUBLIC_BASE_URL=https://dashboard.kontext.observer

# ── Model provider (OpenRouter) ───────────────────────────────────────────────
# Paste your OpenRouter API key here when Railway prompts for env vars.
OPENROUTER_API_KEY=

# The model BusinessClaw uses for all agents.
LLM_MODEL=openrouter/owl-alpha
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=        # same value as OPENROUTER_API_KEY — some layers read this one
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1200
LLM_DAILY_BUDGET_USD=1

# ── Discord ────────────────────────────────────────────────────────────────────
# See docs/DISCORD_SETUP.md for how to create the bot at Discord Developer Portal.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_OWNER_USER_ID=          # your Discord user ID (18-digit number)
DISCORD_OWNER_USER_IDS=         # comma-separated if multiple owners
DISCORD_GUILD_ID=               # your Discord server ID

# ── Dashboard port ─────────────────────────────────────────────────────────────
# Railway injects PORT automatically — leave these blank in Railway variables.
# They are set by scripts/start-production.sh.
HOST=0.0.0.0
PORT=
BUSINESSCLAW_DASHBOARD_PORT=

# ── Wallet (read-only by default) ─────────────────────────────────────────────
WALLET_MODE=read_only
BUSINESSCLAW_WALLET_CHAIN=unset
BUSINESSCLAW_WALLET_PUBLIC_ADDRESS=

# ── Agent safety limits ────────────────────────────────────────────────────────
AGENT_MAX_EMPLOYEES=3
AGENT_MAX_TASK_RUNTIME_MINUTES=30
AGENT_REQUIRE_APPROVAL_FOR_PUBLIC_POSTS=true
AGENT_ALLOW_TOOL_CREATION=true
AGENT_ALLOW_EARNED_CAPITAL_SPEND=true
AGENT_REQUIRE_APPROVAL_FOR_OWNER_FUNDS=true
