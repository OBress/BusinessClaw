# BusinessClaw example environment.
# Copy to .env for local development once implementation starts.

ENVIRONMENT=local
PUBLIC_BASE_URL=http://localhost:3000
AGENT_API_PORT=8080
DASHBOARD_PORT=3000

# LLM provider credentials
LLM_PROVIDER=mock
LLM_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1200
LLM_DAILY_BUDGET_USD=1

# Discord
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_OWNER_USER_ID=
DISCORD_OWNER_USER_IDS=
DISCORD_GUILD_ID=

# Database
DATABASE_URL=sqlite:///./businessclaw.db

# Wallet: start read-only.
WALLET_MODE=read_only
WALLET_PUBLIC_ADDRESS=
WALLET_PRIVATE_KEY=
WALLET_RPC_URL=
WALLET_MAX_AUTO_SPEND_USD=0

# Agent limits
AGENT_MAX_EMPLOYEES=2
AGENT_MAX_TASK_RUNTIME_MINUTES=30
AGENT_REQUIRE_APPROVAL_FOR_PUBLIC_POSTS=true
AGENT_ALLOW_TOOL_CREATION=true
AGENT_ALLOW_EARNED_CAPITAL_SPEND=true
AGENT_REQUIRE_APPROVAL_FOR_OWNER_FUNDS=true
